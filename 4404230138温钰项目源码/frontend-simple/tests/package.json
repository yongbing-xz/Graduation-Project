{
  "name": "project-stability-checker",
  "version": "1.0.0",
  "description": "全面的项目稳定性自动化查验系统",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "init": "node main.js init",
    "full-test": "node main.js full-test",
    "quick-test": "node main.js quick-test",
    "validate-env": "node main.js validate-env",
    "start-scheduler": "node main.js start-scheduler",
    "stop-scheduler": "node main.js stop-scheduler",
    "generate-report": "node main.js generate-report",
    "status": "node main.js status",
    "test": "node main.js full-test",
    "dev": "node main.js quick-test",
    "test:ci": "node test-runner.js --ci",
    "test:dev": "node test-runner.js --env=development",
    "test:prod": "node test-runner.js --env=production",
    "coverage": "node coverage-reporter.js",
    "report": "node report-generator.js"
  },
  "keywords": [
    "stability",
    "testing",
    "automation",
    "monitoring",
    "quality"
  ],
  "author": "Project Stability Team",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.1.0",
    "jsdom": "^22.1.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.4",
    "axios": "^1.5.0",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "yargs": "^17.7.2",
    "puppeteer": "^21.0.0",
    "jest": "^29.0.0",
    "mocha": "^10.0.0",
    "chai": "^4.3.0",
    "winston": "^3.10.0",
    "moment": "^2.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/project-stability-checker.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/project-stability-checker/issues"
  },
  "homepage": "https://github.com/your-org/project-stability-checker#readme"
}